# Normalize line endings to LF on commit
* text=auto eol=lf

# Rust source
*.rs text eol=lf
*.toml text eol=lf
*.lock text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Python
*.py text eol=lf

# Docs
*.md text eol=lf

# Binary
*.gif binary
*.png binary
*.jpg binary
*.mp4 binary
*.db binary

# GitHub Linguist: keep the language bar Rust-first.
# Client SDKs and Helm charts are vendored artifacts, not the core.
sdks/** linguist-vendored
charts/** linguist-vendored
# Documentation should not skew the language stats.
docs/** linguist-documentation
*.md linguist-documentation

# Test, smoke and demo scripts are tooling, not product code: keep them out
# of the language bar (JavaScript + PowerShell).
*.mjs linguist-vendored
*.cjs linguist-vendored
*.ps1 linguist-vendored
