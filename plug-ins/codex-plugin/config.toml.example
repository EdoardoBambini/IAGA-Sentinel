# IAGA Sentinel - OpenAI Codex CLI configuration example.
#
# Hook mechanism CONFIRMED against the pinned Codex version
# (codex-cli 0.138.0-alpha.7, see README.md): Codex's hook engine is
# Claude-Code-compatible (it migrates hooks from `.claude`). Hooks are
# declared in a `hooks.json` (see the sibling `hooks.json` in this folder)
# in the Claude-Code shape:
#
#   { "hooks": { "PreToolUse": [ { "matcher": ".*",
#       "hooks": [ { "type": "command", "command": "<iaga-codex> hook" } ] } ] } }
#
# The gate binary contract is fixed and version-independent: the event JSON
# arrives on stdin (discriminator `hook_event_name`, e.g. "PreToolUse"), the
# gate exits 0 = allow / 2 = block with the justification on stdout.
#
# Two deployment paths:
#
#  1. Developer path: place `hooks.json` where Codex loads user hooks, then
#     TRUST it. Codex pins non-managed hooks by content hash and only loads
#     project hooks once the directory is trusted ("Trusting the directory
#     allows project-local config, hooks, and exec policies to load") - review
#     and approve with `/hooks` in the Codex TUI. Verify the binary checksum
#     against the release artifact before trusting it.
#
#  2. Org-managed path (non-user-disableable): point Codex at a managed hooks
#     directory containing `hooks.json`. Managed hooks are trusted by policy.
#
#  SPIKE NOTE (codex-cli 0.138.0-alpha.7, 2026-06-13): the `[hooks]` keys below
#  set in the USER `config.toml` parse OK but did NOT register the hook
#  (`/hooks` reported 0 installed). The managed-hooks dir is honored only from
#  an admin/MDM `requirements.toml` layer (with `allow_managed_hooks_only`,
#  optionally `allowed_sandbox_modes` to also lock the OS sandbox). On a
#  developer machine, register the hook via the trusted-directory path (1)
#  instead. See STATUS.md.

[hooks]
# Directory that contains `hooks.json`. On Windows Codex reads
# `windows_managed_dir`; on Unix, `managed_dir`. Use an absolute path.
managed_dir = "/abs/path/to/plug-ins/codex-plugin"
windows_managed_dir = "C:\\abs\\path\\to\\examples\\integrations\\codex"

# Notes from the spike (codex-cli 0.138.0-alpha.7):
#  - The gate's own hard timeout is IAGA_CODEX_TIMEOUT_MS (default 1000 ms).
#  - `codex exec --json` (non-interactive) did NOT fire PreToolUse hooks in the
#    spike even when enabled; hooks fire in the interactive TUI. Validate the
#    end-to-end block there, or drive `codex exec --json | iaga-codex ingest`
#    for the advisory (observe + attest) path, which needs no hook at all.
#  - On Windows, if you wrap the gate in a script, use `powershell` (5.1),
#    not `pwsh` (PowerShell 7 may be absent). The binary needs no wrapper.
